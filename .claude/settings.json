{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_MIN_VERIFICATIONS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard origin/master)",
      "Bash(gcloud run services delete *)",
      "Bash(docker system prune -af *)",
      "Bash(mc rm --recursive --force *)",
      "Bash(mc rb --force *)"
    ],
    "ask": [],
    "allow": []
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-completion.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
