{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_MIN_VERIFICATIONS": "1"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard origin/master)",
      "Bash(gcloud run services delete *)",
      "Bash(docker rm -f *)",
      "Bash(docker system prune *)",
      "Bash(mc rm --recursive *)",
      "Bash(mc rb --force *)",
      "Read(./AgoraFront/.claude/secrets.md)",
      "Read(./AgoraFront/.env*)",
      "Read(./AgoraBack/.env*)",
      "Read(./AgoraHub/.env*)",
      "Read(./AgoraWorker/.env*)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.production)",
      "Read(./**/credentials.json)",
      "Read(./**/.credentials.json)",
      "Read(./**/service-account*.json)"
    ],
    "ask": [
      "Bash(vercel deploy *)",
      "Bash(vercel --prod *)",
      "Bash(vercel alias *)",
      "Bash(vercel env rm *)",
      "Bash(gcloud run deploy *)",
      "Bash(docker push *)",
      "Bash(npm publish *)",
      "Bash(git push origin main)",
      "Bash(git push origin master)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run test:*)",
      "Bash(npm test)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx vitest:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(systemctl --user status:*)",
      "Bash(curl -s https://agora.elenxos.com/*)",
      "Bash(vercel ls:*)",
      "Bash(vercel env ls:*)",
      "Bash(vercel inspect:*)",
      "Bash(gcloud logging read:*)",
      "Bash(gcloud run services describe:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-completion.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
